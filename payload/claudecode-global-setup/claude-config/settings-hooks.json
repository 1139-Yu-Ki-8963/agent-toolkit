{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/agent-home/skills/managing-agent-configs/scripts/managing-review-gate.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/agent-home/skills/managing-agent-configs/scripts/managing-commit-gate.sh"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/agents/worker-haiku/scripts/worker-haiku-bash-guard.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/agent-home/skills/managing-agent-configs/scripts/cleanup-session-markers.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
