{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/agent-home/skills/managing-agent-configs/scripts/managing-review-gate.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/agent-home/skills/managing-agent-configs/scripts/managing-commit-gate.sh"
          }
        ]
      }
    ]
  }
}
